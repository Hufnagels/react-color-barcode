{
  "name": "react-color-barcode",
  "version": "0.1.0",
  "description": "React barcode component with per-bar coloring",
  "type": "module",
  "main": "./dist/react-color-barcode.cjs",
  "module": "./dist/react-color-barcode.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/react-color-barcode.js",
      "require": "./dist/react-color-barcode.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0"
  },
  "dependencies": {
    "jsbarcode": "^3.12.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.0.0",
    "@types/react": "^18.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "jsdom": "^24.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^3.0.0",
    "vitest": "^2.0.0"
  },
  "author": "Hufnagels",
  "repository": {
    "type": "git",
    "url": "https://github.com/Hufnagels/react-color-barcode.git"
  },
  "keywords": [
    "react",
    "barcode",
    "color",
    "colored-barcode",
    "svg",
    "jsbarcode",
    "code128",
    "ean13",
    "upc",
    "export"
  ],
  "license": "MIT"
}
